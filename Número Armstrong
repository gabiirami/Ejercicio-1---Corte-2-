#include <cmath>

bool is_armstrong_number(int number) {

    int original = number;
    int digits = 0;
    int temp = number;

    // contar dígitos
    while (temp > 0) {
        digits++;
        temp /= 10;
    }

    temp = number;
    int sum = 0;

    // calcular suma de potencias
    while (temp > 0) {
        int digit = temp % 10;
        sum += pow(digit, digits);
        temp /= 10;
    }

    return sum == original;
}
